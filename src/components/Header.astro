---
import { ui, type Lang } from '../i18n';

interface Props {
  lang: string;
  hasTranslation?: boolean;
  translationPath?: string;
}

const { lang, hasTranslation = false, translationPath } = Astro.props;
const l = lang as Lang;

function t(key: keyof typeof ui['zh-hans']): string {
  return ((ui[l] as typeof ui['zh-hans'])[key] ?? ui['zh-hans'][key]) as string;
}

const navItems: { key: keyof typeof ui['zh-hans']; href: string }[] = [
  { key: 'nav.about', href: `/${lang}/about` },
  { key: 'nav.projects', href: `/${lang}/projects` },
  { key: 'nav.tools', href: `/${lang}/tools` },
  { key: 'nav.learn', href: `/${lang}/learn` },
  { key: 'nav.community', href: `/${lang}/community` },
  { key: 'nav.contribute', href: `/${lang}/contribute` },
];

const currentPath = Astro.url.pathname;
const alternateLang = lang === 'zh-hans' ? 'en' : 'zh-hans';
const alternatePath = translationPath
  ? translationPath
  : currentPath.replace(`/${lang}/`, `/${alternateLang}/`);
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#0a0a0a]/95 backdrop-blur-md border-b border-white/[0.07]" data-pagefind-ignore>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={`/${lang}/`} class="flex items-center gap-3 shrink-0 group" aria-label="MontageSubs 首页">
        <div class="w-9 h-9 bg-[#0a0a0a] border border-yellow-400/40 rounded-md flex items-center justify-center group-hover:border-yellow-400/70 transition-colors">
          <span class="text-yellow-400 font-black text-xl leading-none select-none">M</span>
        </div>
        <span class="text-white/90 font-semibold text-sm hidden sm:block group-hover:text-white transition-colors">
          {lang === 'zh-hans' ? '蒙太奇字幕社区' : 'MontageSubs'}
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map(({ key, href }) => {
          const isActive = currentPath.startsWith(href);
          return (
            <a
              href={href}
              class={`px-3 py-2 rounded-md text-sm transition-colors ${
                isActive
                  ? 'text-yellow-400 bg-yellow-400/5'
                  : 'text-gray-400 hover:text-white hover:bg-white/5'
              }`}
            >
              {t(key)}
            </a>
          );
        })}
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-1 sm:gap-2">

        <!-- Search -->
        <a
          href={`/${lang}/search`}
          class="p-2 text-gray-400 hover:text-white transition-colors rounded-md hover:bg-white/5"
          aria-label={t('nav.search')}
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>

        <!-- Language Switcher -->
        <div class="relative group">
          <button
            class="flex items-center gap-1.5 p-2 text-sm text-gray-400 hover:text-white rounded-md hover:bg-white/5 transition-colors"
            aria-label="切换语言 / Switch language"
            aria-haspopup="true"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="hidden sm:inline text-xs">{lang === 'zh-hans' ? '简体中文' : 'English'}</span>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div class="absolute right-0 top-full mt-1 w-44 py-1 bg-[#1c1c1c] border border-white/10 rounded-lg shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <!-- 简体中文 -->
            <a
              href={lang === 'zh-hans' ? '#' : alternatePath.includes('/en/') ? alternatePath.replace('/en/', '/zh-hans/') : `/${alternateLang}/`}
              class={`flex items-center justify-between px-4 py-2.5 text-sm transition-colors ${
                lang === 'zh-hans'
                  ? 'text-yellow-400 cursor-default'
                  : 'text-gray-300 hover:bg-white/5'
              }`}
              aria-current={lang === 'zh-hans' ? 'true' : undefined}
            >
              <span>简体中文</span>
              {lang === 'zh-hans' && (
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              )}
            </a>

            <!-- English -->
            {lang === 'en' ? (
              <a
                href="#"
                class="flex items-center justify-between px-4 py-2.5 text-sm text-yellow-400 cursor-default"
                aria-current="true"
              >
                <span>English</span>
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </a>
            ) : hasTranslation ? (
              <a
                href={alternatePath}
                class="flex items-center justify-between px-4 py-2.5 text-sm text-gray-300 hover:bg-white/5 transition-colors"
              >
                <span>English</span>
              </a>
            ) : (
              <span class="flex items-center justify-between px-4 py-2.5 text-sm text-gray-600 cursor-not-allowed">
                <span>English</span>
                <span class="text-xs">暂无</span>
              </span>
            )}
          </div>
        </div>

        <!-- CTA Button -->
        <a
          href="https://t.me/MontageSubs"
          class="hidden sm:inline-flex items-center gap-1.5 bg-yellow-400 hover:bg-yellow-300 text-black text-sm font-semibold px-4 py-2 rounded-full transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('nav.join')}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-gray-400 hover:text-white rounded-md hover:bg-white/5 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-white/[0.07] py-3 pb-4">
      <div class="flex flex-col gap-0.5">
        {navItems.map(({ key, href }) => {
          const isActive = currentPath.startsWith(href);
          return (
            <a
              href={href}
              class={`px-3 py-2.5 text-sm rounded-md transition-colors ${
                isActive
                  ? 'text-yellow-400 bg-yellow-400/5'
                  : 'text-gray-400 hover:text-white hover:bg-white/5'
              }`}
            >
              {t(key)}
            </a>
          );
        })}
      </div>
      <div class="mt-4 pt-4 border-t border-white/[0.07]">
        <a
          href="https://t.me/MontageSubs"
          class="flex items-center justify-center bg-yellow-400 hover:bg-yellow-300 text-black text-sm font-semibold py-2.5 rounded-full transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('nav.join')}
        </a>
      </div>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>
