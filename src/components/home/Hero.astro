---
interface Props {
  lang: string;
}
const { lang } = Astro.props;
const isZh = lang === 'zh-hans';
---

<section class="hero" id="hero">
  <div class="hero__content">

    <h1 class="hero__title">
      {isZh
        ? '连接字幕创作者与影视工作者，共建开放的字幕生态'
        : <>Bridging Subtitle Creators<br/>and Filmmakers.<br/><span class="hero__title-line2">Building an Open Subtitle Ecosystem.</span></>
      }
    </h1>

    {isZh && (
      <p class="hero__sub">
        非营利 · 开源 · 社区驱动
      </p>
    )}

    <!-- Scroll indicator -->
    <a href="#who-we-are" class="hero__chevron" aria-label={isZh ? '向下滚动' : 'Scroll down'}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    z-index: 2; /* above beam */
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    width: 100%;
    padding: 0 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: 1.2;
    max-width: 700px;
    letter-spacing: -0.01em;
  }

  .hero__title-line2 {
    color: var(--color-text-primary);
  }

  .hero__sub {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.06em;
  }

  /* Chevron indicator */
  .hero__chevron {
    position: absolute;
    bottom: -40svh; /* near bottom of viewport */
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-text-secondary);
    opacity: 0.55;
    text-decoration: none;
    display: flex;
    animation: chevron-float 2s ease-in-out infinite;
    transition: opacity 0.2s;
  }
  .hero__chevron:hover { opacity: 0.9; }

  @keyframes chevron-float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(5px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__chevron { animation: none; }
  }
</style>
