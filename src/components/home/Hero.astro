---
// Hero.astro
const { t, lang } = Astro.props;
const isChinese = lang === 'zh-hans';
---

<section
  id="hero"
  style="
    position: relative;
    height: 100svh;
    min-height: 600px;
    background-color: var(--color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 2;
  "
  aria-label={isChinese ? '首页主题' : 'Hero section'}
>
  <!-- Content -->
  <div style="
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 1.5rem;
    max-width: 720px;
    width: 100%;
  ">
    <h1 style="
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 500;
      color: var(--color-text-primary);
      line-height: 1.2;
      max-width: 700px;
      margin: 0 auto;
      letter-spacing: -0.02em;
    ">
      {t.hero.title_line1}
      {t.hero.title_line2 && (
        <>
          {isChinese ? '' : <br/>}
          {t.hero.title_line2}
        </>
      )}
      {t.hero.title_line3 && (
        <>
          <br/>
          <span style="color: var(--color-text-secondary);">{t.hero.title_line3}</span>
        </>
      )}
    </h1>

    <!-- Chinese subtitle only -->
    {isChinese && t.hero.subtitle && (
      <p style="
        margin-top: 1.25rem;
        font-size: 0.8125rem;
        color: var(--color-text-secondary);
        letter-spacing: 0.04em;
      ">
        {t.hero.subtitle}
      </p>
    )}

    <!-- Scroll indicator -->
    <div style="margin-top: 3rem; display:flex; justify-content:center;">
      <button
        class="chevron-down"
        onclick="document.getElementById('who-we-are')?.scrollIntoView({ behavior: 'smooth' })"
        aria-label={t.hero.scroll_label}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>
    </div>
  </div>
</section>
