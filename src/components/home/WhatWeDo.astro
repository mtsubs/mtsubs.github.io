---
// WhatWeDo.astro
const { t } = Astro.props;
---

<section
  id="what-we-do"
  style="
    position: relative;
    z-index: 2;
    background-color: var(--color-bg-warm);
    min-height: 100vh;
    padding: 8rem 1.5rem;
    display: flex;
    align-items: center;
  "
  aria-labelledby="what-title"
>
  <div style="max-width: 1100px; margin: 0 auto; width: 100%;">

    <p style="
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
    " aria-hidden="true">
      {t.what.section_label}
    </p>

    <h2
      id="what-title"
      style="
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 500;
        color: var(--color-text-primary);
        letter-spacing: -0.02em;
        margin-bottom: 4rem;
        line-height: 1.15;
      "
    >
      {t.what.title}
    </h2>

    <!-- Pillars -->
    <ul
      style="
        list-style: none;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2.5rem;
      "
      role="list"
    >
      {t.what.pillars.map((p: { title: string; desc: string }) => (
        <li style="
          padding-left: 1.25rem;
          border-left: 2px solid var(--color-accent);
          position: relative;
        ">
          <div style="
            font-size: 1.375rem;
            font-weight: 500;
            color: var(--color-text-primary);
            margin-bottom: 0.75rem;
            letter-spacing: -0.01em;
          ">
            {p.title}
          </div>
          <p style="
            font-size: 0.875rem;
            color: var(--color-text-secondary);
            line-height: 1.65;
          ">
            {p.desc}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
