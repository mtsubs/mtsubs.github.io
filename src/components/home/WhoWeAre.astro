---
// WhoWeAre.astro
const { t } = Astro.props;
---

<section
  id="who-we-are"
  style="
    position: relative;
    z-index: 2;
    background-color: var(--color-bg-warm);
    min-height: 100vh;
    padding: 8rem 1.5rem;
    display: flex;
    align-items: center;
  "
  aria-labelledby="who-title"
>
  <div style="max-width: 1100px; margin: 0 auto; width: 100%;">

    <!-- Section label -->
    <p style="
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
    " aria-hidden="true">
      {t.who.section_label}
    </p>

    <!-- Main title -->
    <h2
      id="who-title"
      style="
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 500;
        color: var(--color-text-primary);
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin-bottom: 2rem;
      "
    >
      {t.who.title}
    </h2>

    <!-- Body text -->
    <p style="
      font-size: 1.0625rem;
      color: var(--color-text-secondary);
      max-width: 600px;
      line-height: 1.75;
      margin-bottom: 4rem;
    ">
      {t.who.body}
    </p>

    <!-- Identity cards grid -->
    <ul
      style="
        list-style: none;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
      "
      role="list"
      aria-label={t.who.title}
    >
      {t.who.identities.map((item: { role: string; desc: string }) => (
        <li
          style="
            border: 1px solid var(--color-border);
            border-radius: 8px;
            padding: 1.5rem;
            background: rgba(255,255,255,0.015);
            transition: border-color 0.2s ease;
          "
        >
          <div style="
            font-size: 1.125rem;
            font-weight: 500;
            color: var(--color-text-primary);
            margin-bottom: 0.5rem;
          ">
            {item.role}
          </div>
          <p style="
            font-size: 0.875rem;
            color: var(--color-text-secondary);
            line-height: 1.55;
          ">
            {item.desc}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
