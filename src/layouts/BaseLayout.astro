---
import '../styles/global.css';
import '../styles/beam.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  hasTranslation?: boolean;
  translationPath?: string;
  ogImage?: string;
  noBeam?: boolean;
}

const {
  title,
  description = 'MontageSubs bridges subtitle creators and filmmakers to build an open, transparent subtitle ecosystem. We create tools, document standards, and foster community.',
  lang = 'zh-hans',
  hasTranslation = false,
  translationPath,
  ogImage,
  noBeam = false,
} = Astro.props;

const siteURL = Astro.site ?? new URL('https://montagesubs.github.io');
const currentURL = Astro.url.href;
const htmlLang = lang === 'zh-hans' ? 'zh-Hans' : 'en';
const alternateLang = lang === 'zh-hans' ? 'en' : 'zh-hans';
const alternatePath = translationPath
  ? new URL(translationPath, siteURL).href
  : currentURL.replace(`/${lang}/`, `/${alternateLang}/`);
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | MontageSubs</title>
    <meta name="description" content={description} />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={currentURL} />
    <link rel="alternate" hreflang={htmlLang} href={currentURL} />
    {hasTranslation && (
      <link rel="alternate" hreflang={lang === 'zh-hans' ? 'en' : 'zh-Hans'} href={alternatePath} />
    )}
    <link rel="alternate" hreflang="x-default" href={new URL('/zh-hans/', siteURL).href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentURL} />
    <meta property="og:title" content={`${title} | MontageSubs`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="MontageSubs" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | MontageSubs`} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml"
      title={`MontageSubs ${lang === 'zh-hans' ? '博客' : 'Blog'}`}
      href={`/${lang}/rss.xml`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Pagefind UI (generated after build) -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

    <!-- Schema.org Organization -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MontageSubs",
      "url": "https://montagesubs.github.io",
      "sameAs": [
        "https://github.com/MontageSubs",
        "https://t.me/MontageSubs"
      ]
    }
    </script>

    <!-- Beam capability detection (inline, < 5 lines) -->
    <script is:inline>
      (function() {
        var h = document.documentElement;
        if (!window.CSS || !CSS.supports('color', 'var(--x)')) {
          h.classList.add('legacy');
        } else if (CSS.supports('animation-timeline', 'scroll()')) {
          h.classList.add('supports-scroll-driven');
        }
      })();
    </script>
  </head>

  <body>
    <!-- Beam layer (aria-hidden, below content) -->
    {!noBeam && <div class="beam" aria-hidden="true" role="presentation"></div>}

    <!-- Navigation -->
    <Header lang={lang} hasTranslation={hasTranslation} translationPath={translationPath} />

    <!-- Page content -->
    <main data-pagefind-body>
      <slot />
    </main>

    <!-- Footer -->
    <Footer lang={lang} />

    <!-- Mobile menu toggle -->
    <script is:inline>
      var btn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', function() {
          var open = menu.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', String(open));
        });
      }
    </script>

    <!-- Search overlay -->
    <div id="search-overlay" class="search-overlay" aria-label="Search" role="dialog" aria-modal="true" hidden>
      <div class="search-overlay__backdrop"></div>
      <div class="search-overlay__box">
        <button id="search-close" aria-label="Close search" class="search-overlay__close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <div id="pagefind-ui"></div>
      </div>
    </div>

    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      var overlay  = document.getElementById('search-overlay');
      var closeBtn = document.getElementById('search-close');
      var searchBtns = document.querySelectorAll('[data-search-trigger]');

      function openSearch() {
        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
        if (typeof PagefindUI !== 'undefined' && !overlay._init) {
          new PagefindUI({ element: '#pagefind-ui', showSubResults: true });
          overlay._init = true;
        }
        setTimeout(function() { overlay.querySelector('input') && overlay.querySelector('input').focus(); }, 50);
      }
      function closeSearch() {
        overlay.hidden = true;
        document.body.style.overflow = '';
      }

      searchBtns.forEach(function(btn) { btn.addEventListener('click', openSearch); });
      if (closeBtn) closeBtn.addEventListener('click', closeSearch);
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeSearch(); });
      if (overlay) overlay.querySelector('.search-overlay__backdrop').addEventListener('click', closeSearch);
    </script>

    <!-- Beam scroll fallback (no-scroll-driven browsers only) -->
    <script is:inline>
      (function() {
        if (document.documentElement.classList.contains('supports-scroll-driven')) return;
        if (document.documentElement.classList.contains('legacy')) return;

        var root = document.documentElement;
        var ticking = false;

        function lerp(a, b, t) { return a + (b - a) * t; }

        function update() {
          var scrollH = document.body.scrollHeight - window.innerHeight;
          if (scrollH <= 0) return;
          var p = Math.min(1, window.scrollY / scrollH);

          var h, blur;
          if (p < 0.25)      { var t = p / 0.25;    h = lerp(4,   20,  t); blur = lerp(2,  8,  t); }
          else if (p < 0.55) { var t = (p-0.25)/0.30; h = lerp(20, 80,  t); blur = lerp(8,  30, t); }
          else if (p < 0.80) { var t = (p-0.55)/0.25; h = lerp(80, 180, t); blur = lerp(30, 60, t); }
          else               { var t = (p-0.80)/0.20; h = lerp(180,300, t); blur = lerp(60, 80, t); }

          root.style.setProperty('--beam-h',    h.toFixed(1) + 'px');
          root.style.setProperty('--beam-blur', blur.toFixed(1) + 'px');
          ticking = false;
        }

        window.addEventListener('scroll', function() {
          if (!ticking) { requestAnimationFrame(update); ticking = true; }
        }, { passive: true });
      })();
    </script>

    <style is:global>
      /* Search overlay */
      .search-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 10vh;
      }
      .search-overlay[hidden] { display: none; }
      .search-overlay__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(8, 8, 8, 0.85);
        backdrop-filter: blur(4px);
      }
      .search-overlay__box {
        position: relative;
        width: min(680px, 90vw);
        background: var(--color-bg-warm);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1.5rem;
        z-index: 1;
      }
      .search-overlay__close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: var(--color-text-secondary);
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 4px;
        line-height: 1;
      }
      .search-overlay__close:hover { color: var(--color-text-primary); }

      /* Section label style */
      .section-label {
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        color: var(--color-text-secondary);
        margin-bottom: 0.75rem;
      }
    </style>
  </body>
</html>
