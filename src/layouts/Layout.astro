---
interface Props {
	title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;
const isZh = pathname.includes('/zh-hans');
---

<!doctype html>
<html lang={isZh ? "zh-Hans" : "en"} class="bg-black">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="text-white selection:bg-yellow-400 selection:text-black">
		<nav class="sticky top-0 z-50 border-b border-white/10 bg-black/80 backdrop-blur-md">
			<div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href={isZh ? "/zh-hans/" : "/en/"} class="flex items-center gap-3 group">
					<div class="w-8 h-8 bg-yellow-400 text-black flex items-center justify-center font-bold rounded-md group-hover:scale-105 transition">M</div>
					<span class="font-bold tracking-tighter text-xl">MONTAGE<span class="text-yellow-400">SUBS</span></span>
				</a>
				
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-400">
					<a href="#" class="hover:text-white transition">关于</a>
					<a href="#" class="hover:text-white transition">项目</a>
					<a href="#" class="hover:text-white transition text-white">工具</a>
					<a href="#" class="hover:text-white transition">学习</a>
					<a href="#" class="hover:text-white transition">社区</a>
					<a href="#" class="hover:text-white transition border border-white/20 px-3 py-1 rounded-full">参与</a>
				</div>

				<div class="flex items-center gap-4 text-xs">
					<a href={isZh ? "/en/" : "/zh-hans/"} class="text-gray-500 hover:text-yellow-400">
						{isZh ? "English" : "中文"}
					</a>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="border-t border-white/10 py-12 mt-20 bg-zinc-950">
			<div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
				<div>
					<div class="font-bold mb-4 flex items-center gap-2">
						<div class="w-6 h-6 bg-yellow-400 text-black flex items-center justify-center text-xs rounded">M</div>
						蒙太奇字幕社区
					</div>
					<p class="text-gray-500 text-sm max-w-sm">
						非营利性开源社区，致力于字幕技术的创新与翻译思维的深度沉淀。版权归原始版权所有者所有，本站仅作学术交流。
					</p>
				</div>
				<div class="flex flex-wrap gap-6 justify-md-end text-gray-400 text-sm">
					<a href="#" class="hover:text-yellow-400">Telegram</a>
					<a href="#" class="hover:text-yellow-400">Discord</a>
					<a href="#" class="hover:text-yellow-400">GitHub</a>
					<a href="#" class="hover:text-yellow-400">DMCA 申诉</a>
				</div>
			</div>
		</footer>
	</body>
</html>