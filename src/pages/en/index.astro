---
// src/pages/en/index.astro
import Nav from '../../components/layout/Nav.astro';
import Footer from '../../components/layout/Footer.astro';
import Hero from '../../components/home/Hero.astro';
import WhoWeAre from '../../components/home/WhoWeAre.astro';
import WhatWeDo from '../../components/home/WhatWeDo.astro';
import Portals from '../../components/home/Portals.astro';
import '../../styles/global.css';
import '../../styles/beam.css';
import '../../styles/nav.css';
import t from '../../i18n/en.json';

const lang = 'en';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />

  <!-- hreflang -->
  <link rel="alternate" hreflang="en" href="/en/" />
  <link rel="alternate" hreflang="zh-Hans" href="/zh-hans/" />
  <link rel="alternate" hreflang="x-default" href="/en/" />

  <!-- Open Graph -->
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:type" content="website" />

  <!-- Schema.org -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MontageSubs",
      "description": "An open, nonprofit subtitle community bridging subtitle creators and filmmakers.",
      "url": "https://montagesubs.github.io"
    }
  </script>

  <!-- Browser feature detection: scroll-driven animation + CSS vars -->
  <script>
    (function() {
      var html = document.documentElement;
      try {
        if (CSS && CSS.supports && CSS.supports('animation-timeline', 'scroll()')) {
          html.classList.add('supports-scroll-driven');
        } else {
          html.classList.add('no-scroll-driven');
        }
        // Check CSS variable support
        if (!CSS.supports('color', 'var(--test)')) {
          html.classList.add('legacy');
        }
      } catch(e) {
        html.classList.add('no-scroll-driven', 'legacy');
      }
    })();
  </script>
</head>
<body>

  <!-- Beam layer: fixed, z-index 1, aria-hidden -->
  <div class="beam-layer" aria-hidden="true">
    <div class="beam-glow"></div>
    <div class="beam-line" id="beam-line"></div>
  </div>

  <!-- Navigation: z-index 100 -->
  <Nav t={t} lang={lang} />

  <!-- Main content: z-index 2 -->
  <main>
    <Hero t={t} lang={lang} />
    <WhoWeAre t={t} lang={lang} />
    <WhatWeDo t={t} lang={lang} />
    <Portals t={t} lang={lang} />
  </main>

  <Footer t={t} lang={lang} />

  <!-- JS fallback for scroll-driven animation (no-scroll-driven browsers) -->
  <script>
    (function() {
      if (!document.documentElement.classList.contains('no-scroll-driven')) return;

      var beam = document.getElementById('beam-line');
      if (!beam) return;

      var ticking = false;

      // Breakpoints: [scroll%, width, blur, opacity]
      var stops = [
        [0,    4,   2,  0.85],
        [0.30, 20,  8,  0.9],
        [0.60, 80,  30, 0.95],
        [0.80, 180, 60, 1.0],
        [1.0,  300, 80, 0.8],
      ];

      function lerp(a, b, t) { return a + (b - a) * t; }

      function interpolate(progress) {
        for (var i = 1; i < stops.length; i++) {
          if (progress <= stops[i][0]) {
            var t = (progress - stops[i-1][0]) / (stops[i][0] - stops[i-1][0]);
            return {
              width:   lerp(stops[i-1][1], stops[i][1], t),
              blur:    lerp(stops[i-1][2], stops[i][2], t),
              opacity: lerp(stops[i-1][3], stops[i][3], t),
            };
          }
        }
        return { width: 300, blur: 80, opacity: 0.8 };
      }

      function update() {
        ticking = false;
        var scrollH = document.body.scrollHeight - window.innerHeight;
        var progress = scrollH > 0 ? window.scrollY / scrollH : 0;
        var v = interpolate(progress);
        var root = document.documentElement;
        root.style.setProperty('--beam-width', v.width + 'px');
        root.style.setProperty('--beam-blur', v.blur + 'px');
        root.style.setProperty('--beam-opacity', String(v.opacity));
      }

      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      }, { passive: true });

      update();
    })();
  </script>

</body>
</html>
