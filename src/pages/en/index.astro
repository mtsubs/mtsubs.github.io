---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/home/Hero.astro';
import WhoWeAre from '../../components/home/WhoWeAre.astro';
import WhatWeDo from '../../components/home/WhatWeDo.astro';
import Portals from '../../components/home/Portals.astro';

const lang = 'en';
---

<BaseLayout
  title="MontageSubs"
  description="MontageSubs — bridging filmmakers and subtitle creators to build an open, transparent subtitle ecosystem."
  lang={lang}
  hasTranslation={true}
  translationPath="/zh-hans/"
>
  <Hero lang={lang} />
  <WhoWeAre lang={lang} />
  <WhatWeDo lang={lang} />
  <Portals lang={lang} />
</BaseLayout>
