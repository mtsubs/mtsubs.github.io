---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

const enProjects = projects.filter(p => p.lang.includes('en'));
---

<BaseLayout
  title="Subtitle Projects"
  description="MontageSubs subtitle translation projects — Shakespeare adaptations, Nordic crime dramas, and more."
  lang="en"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Page Header -->
    <div class="max-w-3xl mb-12">
      <p class="text-accent text-sm font-medium mb-3">Projects</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-primary mb-6 leading-tight">Subtitle Projects</h1>
      <p class="text-secondary text-lg">
        Our subtitle projects balance literary quality with readability. Each project includes translation notes documenting our creative process.
      </p>
    </div>

    <!-- Filter tabs -->
    <div class="flex gap-2 mb-10">
      {(['All', 'Ongoing', 'Completed', 'Paused'] as const).map((label, i) => (
        <button class={`px-4 py-1.5 rounded-full text-sm transition-colors ${
          i === 0
            ? 'bg-accent text-black font-medium'
            : 'border border-wire text-secondary hover:text-primary hover:border-white/30'
        }`}>
          {label}
        </button>
      ))}
    </div>

    <!-- Projects Grid -->
    {enProjects.length === 0 ? (
      <div class="py-20 text-center">
        <p class="text-secondary mb-2">Our projects are currently in Chinese.</p>
        <a href="/zh-hans/projects" class="text-accent hover:underline text-sm">View Chinese projects →</a>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {enProjects.map((project) => (
          <article class="group bg-warm border border-wire rounded-2xl overflow-hidden hover:border-white/20 transition-all">
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${
                  project.status === 'ongoing' ? 'bg-green-400/10 text-green-400' : 'bg-blue-400/10 text-blue-400'
                }`}>
                  {project.status === 'ongoing' ? 'Ongoing' : 'Completed'}
                </span>
              </div>
              <h2 class="text-primary font-semibold mb-2">{project.title_en ?? project.title_zh}</h2>
              <p class="text-secondary text-sm leading-relaxed">{project.description_en ?? project.description_zh}</p>
            </div>
          </article>
        ))}
      </div>
    )}

    <!-- CTA -->
    <div class="mt-16 text-center py-12 border border-wire rounded-2xl">
      <p class="text-secondary mb-2">Interested in contributing to a project?</p>
      <a href="/en/contribute" class="text-accent text-sm hover:underline">Learn how to get involved →</a>
    </div>

  </div>
</BaseLayout>
