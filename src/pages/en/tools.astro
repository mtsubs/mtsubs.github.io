---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tools } from '../../data/tools';
---

<BaseLayout
  title="Tools"
  description="Open-source subtitle tools built and curated by MontageSubs — editors, converters, validators and more."
  lang="en"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Page Header -->
    <div class="max-w-3xl mb-12">
      <p class="text-accent text-sm font-medium mb-3">Tools</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-primary mb-6 leading-tight">Tools Library</h1>
      <p class="text-secondary text-lg">
        A curated collection of open-source subtitle tools covering timeline editing, format conversion, quality checking and more.
      </p>
    </div>

    <!-- Filter -->
    <div class="flex flex-wrap gap-2 mb-10">
      {(['All', 'Online', 'Desktop', 'In Development'] as const).map((label, i) => (
        <button class={`px-4 py-1.5 rounded-full text-sm transition-colors ${
          i === 0 ? 'bg-accent text-black font-medium' : 'border border-wire text-secondary hover:text-primary hover:border-white/30'
        }`}>{label}</button>
      ))}
    </div>

    <!-- Tools Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {tools.map((tool) => (
        <article class="group flex flex-col bg-warm border border-wire rounded-2xl p-6 hover:border-accent/20 transition-all duration-300">
          <div class="flex items-start justify-between mb-4">
            <div class="w-14 h-14 bg-canvas border border-wire rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-accent font-black text-xl">{tool.name.charAt(0)}</span>
            </div>
            <div class="flex flex-col items-end gap-1.5">
              <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${
                tool.type === 'online' ? 'bg-blue-400/10 text-blue-400' : 'bg-purple-400/10 text-purple-400'
              }`}>
                {tool.type === 'online' ? 'Online' : 'Desktop'}
              </span>
              <span class={`text-xs px-2.5 py-1 rounded-full ${
                tool.status === 'active' ? 'bg-green-400/10 text-green-400' : tool.status === 'beta' ? 'bg-accent/10 text-accent' : 'bg-gray-400/10 text-secondary'
              }`}>
                {tool.status === 'active' ? 'Stable' : tool.status === 'beta' ? 'Beta' : 'Archived'}
              </span>
            </div>
          </div>
          <h2 class="text-primary font-semibold text-lg mb-2 group-hover:text-accent transition-colors">{tool.name}</h2>
          <p class="text-secondary text-sm leading-relaxed flex-1 mb-5">{tool.description_en ?? tool.description_zh}</p>
          <div class="flex flex-wrap gap-1.5 mb-5">
            {tool.tags.map((tag) => (
              <span class="text-xs px-2 py-0.5 bg-white/5 border border-wire text-secondary rounded-full font-mono">{tag}</span>
            ))}
          </div>
          <div class="flex items-center justify-between pt-4 border-t border-wire">
            <span class="text-gray-600 text-xs">by {tool.author}</span>
            {tool.url && (
              <a href={tool.url} class="flex items-center gap-1.5 text-accent text-sm hover:underline" target="_blank" rel="noopener noreferrer">
                {tool.type === 'online' ? 'Open Tool' : 'Learn More'}
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Submit CTA -->
    <div class="mt-12 p-8 bg-warm border border-wire rounded-2xl text-center">
      <h3 class="text-primary font-semibold mb-2">Want to submit a tool?</h3>
      <p class="text-secondary text-sm mb-5">We welcome community-built subtitle tools. Currently in review — please contact us by email.</p>
      <a href="mailto:tools@montagesubs.org" class="inline-flex items-center gap-2 border border-accent/30 text-accent hover:bg-accent/5 text-sm px-6 py-2.5 rounded-full transition-colors">
        Submit a Tool
      </a>
    </div>

  </div>
</BaseLayout>
