---
// src/pages/index.astro
// Redirect to appropriate language based on Accept-Language or JS navigator.language
---

<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>MontageSubs</title>
  <script>
    // Redirect to preferred language
    (function() {
      var lang = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
      if (lang.startsWith('zh')) {
        window.location.replace('/zh-hans/');
      } else {
        window.location.replace('/en/');
      }
    })();
  </script>
  <noscript>
    <meta http-equiv="refresh" content="0; url=/en/" />
  </noscript>
</head>
<body>
  <p><a href="/en/">English</a> | <a href="/zh-hans/">中文</a></p>
</body>
</html>
