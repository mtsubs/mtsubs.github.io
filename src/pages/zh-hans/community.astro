---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { members } from '../../data/members';

const roleLabels: Record<string, string> = {
  developer: '开发者',
  translator: '译者',
  editor: '编辑',
  researcher: '研究员',
};
---

<BaseLayout
  title="社区成员"
  description="认识蒙太奇字幕社区的核心成员，了解他们的背景、角色和贡献。"
  lang="zh-hans"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Page Header -->
    <div class="max-w-3xl mb-16">
      <p class="text-accent text-sm font-medium mb-3">社区</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-primary mb-6 leading-tight">社区</h1>
      <p class="text-secondary text-lg">
        我们是一个规模不大但充满热情的团队，来自不同背景，因对字幕事业的热爱而聚集在一起。
      </p>
    </div>

    <!-- Members Section -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold text-primary mb-8">核心成员</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {members.map((member) => {
          return (
            <div class="p-6 bg-warm border border-wire rounded-2xl hover:border-white/20 transition-all duration-300">
              <!-- Avatar -->
              <div class="w-14 h-14 bg-canvas border border-wire rounded-2xl flex items-center justify-center mb-4">
                <span class="text-accent font-bold text-xl">{member.name.charAt(0).toUpperCase()}</span>
              </div>
              <h3 class="text-primary font-semibold text-lg mb-1">{member.name}</h3>
              <!-- Roles -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {member.role.map((r) => (
                  <span class="text-xs px-2.5 py-0.5 bg-accent/10 text-accent/80 rounded-full">
                    {roleLabels[r] ?? r}
                  </span>
                ))}
              </div>
              <p class="text-secondary text-sm leading-relaxed mb-4">{member.bio_zh}</p>
              <!-- Joined -->
              <p class="text-gray-700 text-xs mb-3">加入于 {member.joined}</p>
              <!-- Links -->
              <div class="flex gap-3">
                {member.links.github && (
                  <a
                    href={member.links.github}
                    class="text-secondary hover:text-primary transition-colors text-xs flex items-center gap-1"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                  </a>
                )}
              </div>
            </div>
          );
        })}

        <!-- Join card -->
        <div class="p-6 bg-warm border border-yellow-400/10 border-dashed rounded-2xl flex flex-col items-center justify-center text-center min-h-[200px]">
          <div class="w-14 h-14 border border-accent/20 rounded-2xl flex items-center justify-center mb-4">
            <span class="text-accent text-2xl">+</span>
          </div>
          <h3 class="text-primary font-medium mb-2">这里有你的位置</h3>
          <p class="text-secondary text-sm mb-4">无论你是译者、开发者还是爱好者</p>
          <a href="/zh-hans/contribute" class="text-accent text-sm hover:underline">了解如何加入 →</a>
        </div>
      </div>
    </section>

    <!-- Discussions Section -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold text-primary mb-6">讨论区</h2>
      <div class="p-8 bg-warm border border-wire rounded-2xl flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="flex-1">
          <h3 class="text-primary font-semibold mb-2">GitHub Discussions</h3>
          <p class="text-secondary text-sm leading-relaxed">
            我们使用 GitHub Discussions 作为主要的异步讨论空间，话题涵盖项目讨论、工具建议、翻译问题等。
          </p>
        </div>
        <a
          href="https://github.com/MontageSubs/community/discussions"
          class="shrink-0 inline-flex items-center gap-2 border border-white/20 hover:border-white/40 text-primary text-sm px-5 py-2.5 rounded-full transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          前往讨论区
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </section>

    <!-- Code of Conduct -->
    <section id="conduct" class="scroll-mt-20">
      <h2 class="text-2xl font-bold text-primary mb-6">行为准则</h2>
      <div class="p-8 bg-warm border border-wire rounded-2xl">
        <p class="text-secondary leading-relaxed mb-6">
          我们致力于为所有参与者提供一个友好、安全、包容的环境。以下行为准则适用于所有社区场所。
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { icon: '✓', title: '尊重', desc: '尊重每一位成员，不论背景、技术水平或观点差异' },
            { icon: '✓', title: '建设性', desc: '以建设性的方式提出批评，关注改进而非指责' },
            { icon: '✓', title: '开放', desc: '对不同观点和方法保持开放的心态' },
            { icon: '✗', title: '零容忍', desc: '不容忍骚扰、歧视、人身攻击等任何形式的不当行为' },
          ].map(({ icon, title, desc }) => (
            <div class="flex gap-3">
              <span class={`text-sm font-bold mt-0.5 ${icon === '✓' ? 'text-green-400' : 'text-red-400'}`}>{icon}</span>
              <div>
                <p class="text-primary text-sm font-medium mb-1">{title}</p>
                <p class="text-secondary text-xs leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
        <p class="text-gray-600 text-xs mt-6">
          如遇违规行为，请发送邮件至 <a href="mailto:conduct@montagesubs.org" class="text-accent hover:underline">conduct@montagesubs.org</a>
        </p>
      </div>
    </section>

  </div>
</BaseLayout>
