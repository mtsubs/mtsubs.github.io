---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/home/Hero.astro';
import WhoWeAre from '../../components/home/WhoWeAre.astro';
import WhatWeDo from '../../components/home/WhatWeDo.astro';
import Portals from '../../components/home/Portals.astro';

const lang = 'zh-hans';
---

<BaseLayout
  title="蒙太奇字幕社区"
  description="蒙太奇字幕社区 — 连接影视工作者、字幕创作者与开发者，共同构建开放、透明的字幕生态。"
  lang={lang}
  hasTranslation={true}
  translationPath="/en/"
>
  <Hero lang={lang} />
  <WhoWeAre lang={lang} />
  <WhatWeDo lang={lang} />
  <Portals lang={lang} />
</BaseLayout>
