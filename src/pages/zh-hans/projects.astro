---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

const zhProjects = projects.filter(p => p.lang.includes('zh'));
---

<BaseLayout
  title="字幕项目"
  description="蒙太奇字幕社区的所有字幕翻译项目，包含莎士比亚系列、北欧犯罪剧等。"
  lang="zh-hans"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Page Header -->
    <div class="max-w-3xl mb-12">
      <p class="text-accent text-sm font-medium mb-3">项目</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-primary mb-6 leading-tight">字幕项目</h1>
      <p class="text-secondary text-lg">
        我们的字幕项目注重文学性与可读性的平衡。每个项目都附带翻译思维记录，记录我们的创作过程。
      </p>
    </div>

    <!-- Filter tabs -->
    <div class="flex gap-2 mb-10">
      {(['全部', '进行中', '已完成', '暂停'] as const).map((label, i) => (
        <button class={`px-4 py-1.5 rounded-full text-sm transition-colors ${
          i === 0
            ? 'bg-accent text-black font-medium'
            : 'border border-wire text-secondary hover:text-primary hover:border-white/30'
        }`}>
          {label}
        </button>
      ))}
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {zhProjects.map((project) => (
        <article class="group bg-warm border border-wire rounded-2xl overflow-hidden hover:border-white/20 transition-all duration-300">
          <!-- Poster area -->
          <div class="aspect-[2/3] max-h-48 bg-canvas flex items-center justify-center border-b border-wire overflow-hidden">
            {project.tmdb_poster_path ? (
              <img
                src={`https://image.tmdb.org/t/p/w342${project.tmdb_poster_path}`}
                alt={project.title_zh}
                width="342"
                height="513"
                loading="lazy"
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="text-gray-700 text-center p-6">
                <svg class="w-12 h-12 mx-auto mb-2 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
                </svg>
                <p class="text-xs">暂无海报</p>
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="p-6">
            <!-- Status badge -->
            <div class="flex items-center justify-between mb-3">
              <span class={`inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full font-medium ${
                project.status === 'ongoing'
                  ? 'bg-green-400/10 text-green-400'
                  : project.status === 'completed'
                  ? 'bg-blue-400/10 text-blue-400'
                  : 'bg-gray-400/10 text-secondary'
              }`}>
                <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                {project.status === 'ongoing' ? '进行中' : project.status === 'completed' ? '已完成' : '暂停'}
              </span>
              {project.year && <span class="text-gray-600 text-xs">{project.year}</span>}
            </div>

            <h2 class="text-primary font-semibold mb-2 group-hover:text-accent transition-colors">
              {project.title_zh}
            </h2>
            <p class="text-secondary text-sm leading-relaxed mb-4 line-clamp-3">
              {project.description_zh}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {project.tags_zh.map((tag) => (
                <span class="text-xs px-2 py-0.5 bg-white/5 border border-wire text-secondary rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state or more coming -->
    <div class="mt-12 text-center py-12 border border-wire rounded-2xl">
      <p class="text-secondary mb-2">更多项目正在进行中</p>
      <a href="/zh-hans/contribute" class="text-accent text-sm hover:underline">想参与我们的项目？→</a>
    </div>

  </div>
</BaseLayout>
