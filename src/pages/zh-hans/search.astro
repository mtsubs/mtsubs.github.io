---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="搜索"
  description="搜索蒙太奇字幕社区的内容"
  lang="zh-hans"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="max-w-2xl mx-auto">
      <div class="mb-10">
        <p class="text-accent text-sm font-medium mb-3">搜索</p>
        <h1 class="text-4xl font-bold text-primary mb-4">搜索内容</h1>
        <p class="text-secondary">搜索博客文章、教程、工具和项目信息。</p>
      </div>

      <!-- Pagefind UI will be injected here -->
      <div id="search" class="pagefind-ui-wrapper"></div>

      <!-- Search widget -->
      <div class="mt-6 p-6 bg-warm border border-wire rounded-2xl text-center text-secondary text-sm">
        <p>搜索功能在 GitHub Pages 上线后可用。本地构建环境下需先运行 <code class="bg-gray-900 text-accent px-1 py-0.5 rounded text-xs">npx pagefind --site dist</code> 以生成搜索索引。</p>
      </div>
    </div>

  </div>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof PagefindUI !== 'undefined') {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: '输入关键词…',
          zero_results: '未找到结果',
        },
      });
    }
  });
</script>
